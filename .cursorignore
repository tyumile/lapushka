# -----------------------------
# Cursor ignore (reduce context / noise)
# -----------------------------

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp
*.bak

# Git
.git/
.git/**

# Node / JS
node_modules/
bower_components/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
out/
.next/
.nuxt/
.cache/
.eslintcache
*.min.js
*.map

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.venv/
venv/
ENV/
env/
pip-wheel-metadata/
*.egg-info/
.eggs/

# Java / Kotlin / Gradle
.gradle/
build/
out/
*.class

# Go
bin/
pkg/
*.exe
*.test

# Rust
target/

# .NET
bin/
obj/
*.user
*.suo

# C/C++ build
CMakeFiles/
CMakeCache.txt
cmake-build-*/
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib

# Logs / runtime artifacts
logs/
*.log
*.pid
*.sqlite
*.db
coverage/
.nyc_output/

# Docker / containers
**/.docker/
**/docker-data/

# Large media / binaries (usually useless for LLM context)
*.zip
*.7z
*.rar
*.tar
*.gz
*.tgz
*.bz2
*.iso
*.dmg
*.exe
*.msi
*.apk
*.aab
*.jar
*.war

# Images / video / audio
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
*.ico
*.mp4
*.mov
*.mkv
*.avi
*.mp3
*.wav
*.ogg

# Documents (often huge; enable if you don't need AI to read them)
*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.xls
*.xlsx

# Secrets (keep OUT of context)
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/